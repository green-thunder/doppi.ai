# Postgres connection string. Local dev example (Homebrew postgres, no password):
#   postgresql://USER@localhost:5432/doppi_ai?schema=public
# Production (e.g. Neon/Supabase): use the pooled connection string they give you.
DATABASE_URL="postgresql://USER@localhost:5432/doppi_ai?schema=public"

# Admin panel (/admin) login password. Change this.
ADMIN_PASSWORD="change-me"

# Long random string used to sign the admin session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SECRET="generate-a-long-random-hex-string"

# CRM: which organization (by slug) receives website leads from the landing
# contact form. Defaults to "doppi" (created by `npm run db:seed`).
LEADS_ORG_SLUG="doppi"

# CRM team invites — optional email delivery via Resend (https://resend.com).
# If RESEND_API_KEY is unset, invites still work: the accept link is shown in the
# UI for the admin to copy/share. Set a verified sender for production.
RESEND_API_KEY=""
RESEND_FROM="Do'ppi CRM <onboarding@resend.dev>"

# Absolute base URL used to build invite links (e.g. https://doppi.ai). When
# unset, the app derives it from the incoming request host.
NEXT_PUBLIC_APP_URL=""

# CRM AI assistant (/crm/assistant) — powered by the Anthropic API. Leave the key
# empty to disable the assistant (the UI shows a "not configured" message).
ANTHROPIC_API_KEY=""
# Optional: override the model. Defaults to claude-opus-4-8 (most capable).
# Cheaper/faster options: claude-sonnet-5, claude-haiku-4-5.
CRM_AI_MODEL="claude-opus-4-8"
